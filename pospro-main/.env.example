# GEMINI_API_KEY: Optional. Integrasi Google Gemini bersifat opsional.
# Dependency `@google/genai` telah dihapus dari package.json.
# Untuk mengaktifkan kembali: instal `@google/genai` dan set `GEMINI_API_KEY`.

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ===== SUPABASE CONFIGURATION =====
# Dapatkan credentials dari https://supabase.com
# 1. Buat project baru di Supabase
# 2. Cari "API" di sidebar
# 3. Copy "Project URL" dan "anon public key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"
